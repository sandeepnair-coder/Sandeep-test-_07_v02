# Fynd Studio — Local Environment Variables
# 1. Copy this file:  cp .env.example .env.local
# 2. Replace the placeholder values below with your actual API keys
# 3. Run:  vercel dev

# Anthropic Claude API Key (get from https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# PixelBin API Token (get from PixelBin dashboard → Settings → Tokens)
PIXELBIN_API_TOKEN=your-pixelbin-api-token-here
